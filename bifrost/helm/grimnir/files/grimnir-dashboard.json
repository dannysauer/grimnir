{
  "title": "Grimnir — CSI Localization",
  "uid": "grimnir-csi-001",
  "description": "Wi-Fi CSI human presence detection — Geri aggregator + Freki API",
  "tags": ["grimnir", "csi", "iot"],
  "timezone": "default",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Data Source",
        "hide": 0
      },
      {
        "name": "namespace",
        "type": "custom",
        "label": "Namespace",
        "query": "grimnir",
        "current": { "text": "grimnir", "value": "grimnir" },
        "options": [{ "text": "grimnir", "value": "grimnir", "selected": true }],
        "hide": 0
      },
      {
        "name": "release",
        "type": "custom",
        "label": "Release",
        "query": "grimnir",
        "current": { "text": "grimnir", "value": "grimnir" },
        "options": [{ "text": "grimnir", "value": "grimnir", "selected": true }],
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Geri — UDP Aggregator",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Packet Ingestion Rate",
      "description": "UDP CSI packets received per second, by receiver",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "min": 0
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(geri_packets_received_total{namespace=\"$namespace\"}[1m])",
          "legendFormat": "{{receiver_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Invalid Packets / s",
      "description": "UDP packets that failed parsing (bad magic, truncated, etc.)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "rate(geri_packets_invalid_total{namespace=\"$namespace\"}[1m])",
          "legendFormat": "invalid/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Dropped Packets / s",
      "description": "Packets dropped due to full internal queue",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "rate(geri_packets_dropped_total{namespace=\"$namespace\"}[1m])",
          "legendFormat": "dropped/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Batch Write Rate",
      "description": "DB batch writes per second (success / error)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "min": 0 }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(geri_batch_writes_total{namespace=\"$namespace\", status=\"success\"}[1m])",
          "legendFormat": "success",
          "refId": "A"
        },
        {
          "expr": "rate(geri_batch_writes_total{namespace=\"$namespace\", status=\"error\"}[1m])",
          "legendFormat": "error",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Batch Write Latency",
      "description": "p50 and p95 batch write duration",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(geri_batch_write_duration_seconds_bucket{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(geri_batch_write_duration_seconds_bucket{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Freki — API",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "description": "API requests per second by endpoint",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_request_duration_seconds_count{namespace=\"$namespace\", job=~\"$release-freki\"}[1m]))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP Latency p50 / p95",
      "description": "Request duration percentiles across all API endpoints",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"$release-freki\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"$release-freki\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "SSE Connections Active",
      "description": "Number of open /api/stream SSE connections",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 26, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(freki_sse_connections_active{namespace=\"$namespace\"})",
          "legendFormat": "connections",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "stat",
      "title": "HTTP Error Rate",
      "description": "5xx responses per second",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 6, "y": 26, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{namespace=\"$namespace\", job=~\"$release-freki\", status=~\"5..\"}[1m]))",
          "legendFormat": "5xx/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Infrastructure",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "CPU Usage",
      "description": "CPU cores used by each Grimnir container",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by (container) (rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"$release-.*\", container!=\"\", container!=\"POD\"}[1m]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Memory Usage",
      "description": "Working set memory for each Grimnir container",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0 }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by (container) (container_memory_working_set_bytes{namespace=\"$namespace\", pod=~\"$release-.*\", container!=\"\", container!=\"POD\"})",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    }
  ]
}
