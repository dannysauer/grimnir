# .env.example — copy to .env and fill in your values
# Never commit .env to version control

# PostgreSQL connection string — points at humpy (external NAS with TimescaleDB)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://csi_user:changeme@humpy.home.arpa:5432/csi

# Aggregator UDP port (must match AGGREGATOR_PORT in firmware/config.h)
UDP_PORT=5005

# Backend HTTP port
BACKEND_PORT=8000

# Logging level (debug, info, warning, error)
LOG_LEVEL=info
